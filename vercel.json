{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/css/(.*)", "destination": "/frontend/css/$1" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" },
    { "source": "/admin/css/(.*)", "destination": "/frontend/admin/css/$1" },
    { "source": "/admin/js/(.*)", "destination": "/frontend/admin/js/$1" },
    { "source": "/admin", "destination": "/frontend/admin/index.html" },
    { "source": "/admin/(.*)", "destination": "/frontend/admin/$1" },
    { "source": "/dashboard", "destination": "/frontend/dashboard.html" },
    { "source": "/subject", "destination": "/frontend/subject.html" },
    { "source": "/view_document", "destination": "/frontend/view_document.html" },
    { "source": "/profile", "destination": "/frontend/profile.html" },
    { "source": "/forgot_password", "destination": "/frontend/forgot_password.html" },
    { "source": "/reset_password", "destination": "/frontend/reset_password.html" },
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/((?!api/).*)", "destination": "/frontend/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization" }
      ]
    }
  ]
}
