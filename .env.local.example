# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Email (SMTP via Brevo, Gmail, etc.) ────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login@email.com
SMTP_PASS=your_brevo_smtp_key
SMTP_FROM=noreply@gsfcuniversity.ac.in
SMTP_NAME=StudyShare

# ─── App URL ─────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL after first deploy
APP_URL=https://your-app.vercel.app
