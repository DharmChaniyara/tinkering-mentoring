# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: Supabase → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up free at https://resend.com → API Keys → Create API Key
# Free tier: 3,000 emails/month, no credit card needed.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — must be a domain you verify in Resend
# For testing you can use: onboarding@resend.dev
RESEND_FROM=StudyShare <noreply@gsfcuniversity.ac.in>

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# GMAIL_USER: Your full Gmail address
# GMAIL_APP_PASSWORD: 16-character code from Google Account → Security → App Passwords
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── App URL ─────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL after first deploy
APP_URL=https://study-share.vercel.app
